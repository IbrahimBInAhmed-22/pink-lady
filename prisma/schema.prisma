generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String
  rides    Ride[]
}

model Ride {
  id        Int      @id @default(autoincrement())
  pickup    String
  drop      String
  status    String
  fare      Float
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}